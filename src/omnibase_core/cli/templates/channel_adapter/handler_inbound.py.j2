def get_bot_token() -> str:
    """Read the {{ Platform }} bot token from environment."""
    token = os.environ.get("{{ platform | upper }}_BOT_TOKEN", "")
    if not token:
        msg = "{{ platform | upper }}_BOT_TOKEN environment variable is not set"
        raise RuntimeError(msg)
    return token


