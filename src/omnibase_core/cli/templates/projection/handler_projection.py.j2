def handle_projection_event(event: dict[str, Any]) -> dict[str, Any]:
    """Project an incoming event into the {{ projection_name }} read model.

    Records data_provenance on every written row so consumers can distinguish
    measured data from seeded or estimated values.

    Args:
        event: The raw event payload from the event bus.

    Returns:
        A projection row dict ready for persistence.
    """
    # TODO(OMN-XXXX): Extract fields from event and build projection row.
    provenance_raw = event.get("data_provenance", "")
    provenance = EnumDataProvenance(provenance_raw) if provenance_raw else None
    if provenance is None or provenance not in EnumDataProvenance:
        provenance = EnumDataProvenance.UNKNOWN

    raise NotImplementedError(
        "{{ projection_name }} projection handler not yet implemented — "
        "map event fields to the projection row and set data_provenance"
    )
